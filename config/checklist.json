{
  "$schema": "https://github.com/bigbite/mediapress/packages/checklist/config-schema.json",
  "items": [
    {
      "name": "has_headline",
      "title": "Has a headline",
      "type": "blocking",
      "check": {
        "type": "exists",
        "sourceKey": "title"
      },
      "messages": {
        "pass": "Has a Headline",
        "fail": "Headline is missing"
      },
      "postTypes": ["post"]
    },
    {
      "name": "has_short_headline",
      "title": "Has a short headline",
      "type": "non_blocking",
      "check": {
        "type": "exists",
        "sourceKey": "meta.short_headline"
      },
      "messages": {
        "pass": "Has a short headline",
        "fail": "Short Headline is missing"
      },
      "postTypes": ["post"]
    },
    {
      "name": "has_standfirst",
      "title": "Has a standfirst",
      "type": "non_blocking",
      "check": {
        "type": "exists",
        "sourceKey": "meta.standfirst"
      },
      "messages": {
        "pass": "Has a Standfirst",
        "fail": "Standfirst is missing"
      },
      "postTypes": ["post"]
    },
    {
      "name": "has_excerpt",
      "title": "Has an excerpt",
      "type": "non_blocking",
      "check": {
        "type": "exists",
        "sourceKey": "excerpt"
      },
      "messages": {
        "pass": "Has an Excerpt",
        "fail": "Excerpt is missing"
      },
      "postTypes": ["post"]
    },
    {
      "name": "has_seo_headline",
      "title": "Has SEO Headline",
      "type": "blocking",
      "check": {
        "type": "exists",
        "sourceKey": "meta.seo_headline"
      },
      "messages": {
        "pass": "Has an SEO Headline",
        "fail": "SEO Headline is missing"
      },
      "postTypes": ["post"]
    },
    {
      "name": "seo_headline_length",
      "title": "SEO Headline has between 50-70 characters",
      "type": "non_blocking",
      "check": {
        "type": "range",
        "min": 50,
        "max": 70,
        "sourceKey": "meta.seo_headline"
      },
      "messages": {
        "pass": "SEO Headline is between 50-70 characters",
        "fail": "SEO Headline should be between 50-70 characters"
      },
      "postTypes": ["post"]
    },
    {
      "name": "has_seo_description",
      "title": "Has SEO Description",
      "type": "blocking",
      "check": {
        "type": "exists",
        "sourceKey": "meta.seo_description"
      },
      "messages": {
        "pass": "Has an SEO Description",
        "fail": "SEO Description is missing"
      },
      "postTypes": ["post"]
    },
    {
      "name": "seo_description_length",
      "title": "SEO Description has between 155-160 characters",
      "type": "non_blocking",
      "check": {
        "type": "range",
        "min": 155,
        "max": 160,
        "sourceKey": "meta.seo_description"
      },
      "messages": {
        "pass": "SEO Description is between 155-160 characters",
        "fail": "SEO Description should be between 155-160 characters"
      },
      "postTypes": ["post"]
    },
    {
      "name": "has_approved_review",
      "type": "custom",
      "postTypes": ["post"]
    }
  ],
  "groups": [
    {
      "name": "content",
      "title": "Content Checks",
      "items": ["has_headline", "has_short_headline", "has_standfirst", "has_excerpt"]
    },
    {
      "name": "seo",
      "title": "SEO Checks",
      "items": ["has_seo_headline", "seo_headline_length", "has_seo_description", "seo_description_length"]
    }
  ]
}